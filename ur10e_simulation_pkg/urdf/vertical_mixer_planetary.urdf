<?xml version="1.0"?>
<!--
  vertical_mixer_planetary.urdf
  MY-300 Planetary Mixer — Gazebo Classic (gazebo_ros2_control)

  Gear constants:  S=4  P=2  R=8
    θ_shroud =  θ_sun / 3   (same direction)
    θ_orbit  =  θ_sun / 3   (same as shroud)
    θ_spin   = -4/3 × θ_sun (opposite to sun)

  Link hierarchy
  ──────────────
  world (fixed)
  └─ base_link              (fixed to world)
     ├─ sun_link            (sun_joint       – continuous, z)
     ├─ shroud_link         (shroud_joint    – continuous, z)
     ├─ planet_1_carrier    (planet_1_orbit_joint – continuous, z)
     │  └─ planet_1_link   (planet_1_spin_joint  – continuous, z)
     └─ planet_2_carrier    (planet_2_orbit_joint – continuous, z)
        └─ planet_2_link   (planet_2_spin_joint  – continuous, z)

  All inertia values are for solid cylinders:
    Ixx = Iyy = (1/12)*m*(3r² + h²)
    Izz       = (1/2) *m* r²
-->
<robot name="planetary_mixer">

  <!-- ═══════════════════════ WORLD (fixed ground) ════════════════════════ -->
  <link name="world"/>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════ BASE LINK ══════════════════════════════════ -->
  <!-- Cylinder r=0.15 m, h=0.05 m, m=2.0 kg
       CoM at link origin (0, 0, 0).
       Ixx=Iyy=(1/12)*2.0*(3*0.15²+0.05²)=0.01167  Izz=(1/2)*2.0*0.15²=0.0225 -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.15" length="0.05"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.15" length="0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01167" ixy="0" ixz="0"
               iyy="0.01167" iyz="0"
               izz="0.0225"/>
    </inertial>
  </link>

  <!-- ═══════════════════════ SUN LINK ════════════════════════════════════ -->
  <!-- Cylinder r=0.04 m, h=0.10 m, m=0.5 kg
       CoM at (0, 0, 0.05) in the sun_joint frame.
       Ixx=Iyy=(1/12)*0.5*(3*0.04²+0.10²)=6.17e-4  Izz=(1/2)*0.5*0.04²=4e-4 -->
  <link name="sun_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry>
      <material name="yellow"><color rgba="1.0 0.85 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000617" ixy="0" ixz="0"
               iyy="0.000617" iyz="0"
               izz="0.0004"/>
    </inertial>
  </link>

  <joint name="sun_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="sun_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ═══════════════════════ SHROUD LINK ═════════════════════════════════ -->
  <!-- Hollow-ring approximated as cylinder r=0.14 m, h=0.10 m, m=1.0 kg
       CoM at (0, 0, 0.05) in the shroud_joint frame.
       Ixx=Iyy=(1/12)*1.0*(3*0.14²+0.10²)=5.73e-3  Izz=(1/2)*1.0*0.14²=9.8e-3 -->
  <link name="shroud_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.14" length="0.10"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 0.4"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.14" length="0.10"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00573" ixy="0" ixz="0"
               iyy="0.00573" iyz="0"
               izz="0.0098"/>
    </inertial>
  </link>

  <joint name="shroud_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="shroud_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ═══════════════════════ PLANET 1 CARRIER ═══════════════════════════ -->
  <!-- Disc r=0.025 m, h=0.02 m, m=0.2 kg  (offset +x from orbit joint origin)
       CoM at (0.08, 0, 0.01) in the planet_1_orbit_joint frame.
       Ixx=Iyy=(1/12)*0.2*(3*0.025²+0.02²)=3.79e-5  Izz=(1/2)*0.2*0.025²=6.25e-5 -->
  <link name="planet_1_carrier">
    <visual>
      <origin xyz="0.08 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.02"/></geometry>
      <material name="orange"><color rgba="1.0 0.5 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.08 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.08 0 0.01" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0000379" ixy="0" ixz="0"
               iyy="0.0000379" iyz="0"
               izz="0.0000625"/>
    </inertial>
  </link>

  <joint name="planet_1_orbit_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="planet_1_carrier"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ═══════════════════════ PLANET 1 LINK ══════════════════════════════ -->
  <!-- Cylinder r=0.02 m, h=0.08 m, m=0.1 kg
       CoM at (0, 0, 0.04) in the planet_1_spin_joint frame.
       Ixx=Iyy=(1/12)*0.1*(3*0.02²+0.08²)=6.33e-5  Izz=(1/2)*0.1*0.02²=2e-5 -->
  <link name="planet_1_link">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.08"/></geometry>
      <material name="green"><color rgba="0.0 0.7 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000633" ixy="0" ixz="0"
               iyy="0.0000633" iyz="0"
               izz="0.00002"/>
    </inertial>
  </link>

  <joint name="planet_1_spin_joint" type="continuous">
    <parent link="planet_1_carrier"/>
    <child  link="planet_1_link"/>
    <origin xyz="0.08 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ═══════════════════════ PLANET 2 CARRIER ═══════════════════════════ -->
  <!-- Mirror of planet 1 at -x offset (180° apart), same geometry.
       CoM at (0.08, 0, 0.01) in the planet_2_orbit_joint frame (joint is
       rotated 180° about z, so CoM maps to (-0.08, 0, 0.01) in base_link).
       Ixx=Iyy=(1/12)*0.2*(3*0.025²+0.02²)=3.79e-5  Izz=(1/2)*0.2*0.025²=6.25e-5 -->
  <link name="planet_2_carrier">
    <visual>
      <origin xyz="-0.08 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.02"/></geometry>
      <material name="orange2"><color rgba="1.0 0.5 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.08 0 0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.08 0 0.01" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0000379" ixy="0" ixz="0"
               iyy="0.0000379" iyz="0"
               izz="0.0000625"/>
    </inertial>
  </link>

  <joint name="planet_2_orbit_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="planet_2_carrier"/>
    <origin xyz="0 0 0.025" rpy="0 0 3.14159265"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ═══════════════════════ PLANET 2 LINK ══════════════════════════════ -->
  <!-- Same geometry as planet_1_link.
       CoM at (0, 0, 0.04) in the planet_2_spin_joint frame.
       Ixx=Iyy=(1/12)*0.1*(3*0.02²+0.08²)=6.33e-5  Izz=(1/2)*0.1*0.02²=2e-5 -->
  <link name="planet_2_link">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.08"/></geometry>
      <material name="green2"><color rgba="0.0 0.7 0.3 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000633" ixy="0" ixz="0"
               iyy="0.0000633" iyz="0"
               izz="0.00002"/>
    </inertial>
  </link>

  <joint name="planet_2_spin_joint" type="continuous">
    <parent link="planet_2_carrier"/>
    <child  link="planet_2_link"/>
    <origin xyz="0.08 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ═══════════════════════ ROS 2 CONTROL ══════════════════════════════ -->
  <ros2_control name="planetary_mixer_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="sun_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="shroud_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="planet_1_orbit_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="planet_1_spin_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="planet_2_orbit_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="planet_2_spin_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════ GAZEBO PLUGIN ══════════════════════════════ -->
  <!--
    The launch file replaces CONTROLLERS_YAML_PLACEHOLDER with the
    absolute path to the installed controllers.yaml at launch time.
  -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>CONTROLLERS_YAML_PLACEHOLDER</parameters>
    </plugin>
  </gazebo>

</robot>
